# ═══════════════════════════════════════════════════════════
# Eclipse Store Bot — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o arquivo .env com valores reais!
# ═══════════════════════════════════════════════════════════

# ─── OBRIGATÓRIAS ──────────────────────────────────────────
BOT_TOKEN=seu_token_aqui
MONGO_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/nome_db

# ─── OPCIONAIS ─────────────────────────────────────────────

# SECRET para sessões web (gere um valor aleatório seguro)
SESSION_SECRET=mude_para_string_aleatoria_segura

# URL da API de pagamentos interna (padrão: http://localhost:3001)
PAY_API_URL=http://localhost:3001

# Webhook do Discord para logs de erros críticos
ERROR_WEBHOOK_URL=

# ─── INTEGRAÇÃO SYNC/CLOUD (opcional) ─────────────────────
SYNC_SERVER_URL=https://manager.syncapplications.com.br

# ─── NUBANK / PIX (se usar integração IMAP) ───────────────
NUBANK_EMAIL=
NUBANK_EMAIL_PASSWORD=

# ─── AMBIENTE ─────────────────────────────────────────────
# "production" ou "development"
ENV=production

